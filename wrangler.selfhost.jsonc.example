// Copy the fields below into your `wrangler.jsonc` (top-level + `env.development` if you use `bun run dev`).
// Do not commit real secrets here. See SELF_HOSTING.md for the full procedure.
{
	"name": "YOUR_WORKER_NAME",
	"r2_buckets": [
		{
			"binding": "ATTACHMENTS",
			"bucket_name": "YOUR_ATTACHMENTS_BUCKET",
			"preview_bucket_name": "YOUR_ATTACHMENTS_PREVIEW_BUCKET"
		}
	],
	"ratelimits": [
		{
			"name": "API_RATE_LIMITER",
			"namespace_id": "YOUR_UNIQUE_NAMESPACE_ID",
			"simple": { "limit": 120, "period": 60 }
		}
	],
	"vars": {
		"APP_URL": "https://YOUR_PUBLIC_ORIGIN",
		"ENVIRONMENT": "production",
		"VERSION_PREFIX": "1",
		"TEST_STRING": "w4KPFgvgr4"
	}
}
