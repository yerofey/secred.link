{
	"name": "secred.link",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun run build:frontend && wrangler dev --env development",
		"dev:frontend": "bun run --cwd apps/frontend dev",
		"build": "bun run build:frontend && bun run typecheck",
		"build:frontend": "bun run --cwd apps/frontend build",
		"preview": "bun run build:frontend && wrangler dev --env development --local",
		"deploy": "bun run build:frontend && wrangler deploy --env=\"\"",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"test": "bun test",
		"typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p apps/backend/tsconfig.json && tsc --noEmit -p apps/frontend/tsconfig.json",
		"cf:typegen": "wrangler types apps/backend/src/worker-configuration.d.ts",
		"selfhost:check": "bun scripts/selfhost-preflight.ts"
	},
	"dependencies": {
		"@noble/hashes": "^2.2.0",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tiptap/extension-link": "^3.22.5",
		"@tiptap/extension-placeholder": "^3.22.5",
		"@tiptap/react": "^3.22.5",
		"@tiptap/starter-kit": "^3.22.5",
		"@vitejs/plugin-react": "^6.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"crypto-js": "^4.2.0",
		"isomorphic-dompurify": "^3.12.0",
		"lucide-react": "^1.9.0",
		"marked": "^18.0.3",
		"nanoid": "^5.1.9",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.11.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.4.0",
		"turndown": "^7.2.4",
		"wrangler": "^4.55.0",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@cloudflare/workers-types": "^4.20260424.0",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/bun": "^1.3.14",
		"@types/crypto-js": "^4.2.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/turndown": "^5.0.6",
		"postcss": "^8.5.10",
		"tailwindcss": "^4.1.18",
		"typescript": "^6.0.3",
		"vite": "^8.0.10"
	}
}
